# ─── BizHealth Environment Variables ────────────────────────────────────────
# Copy this file to .env.local for local development.
# NEVER commit .env.local to git.

# Required: Your Groq API key (AI report generation)
# Get it free at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Required (production): Your Paystack Secret Key (server-side payment verification)
# Get it at: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_live_your_key_here

# Required (frontend): Your Paystack Public Key (client-side payment popup)
# Add this in Vercel under Project → Settings → Environment Variables
VITE_PAYSTACK_PUBLIC_KEY=pk_live_your_key_here

# Optional: Admin dashboard password (default: bizhealth2025)
VITE_ADMIN_PASSWORD=your_secure_password_here
